# PentestGPT Configuration
# Copy this file to .env if you want to customize settings

# =============================================================================
# Claude Configuration
# =============================================================================
# Claude Code manages its own API configuration.
# Configure with: claude config (inside container)

# Optional: Claude model to use
# Options: claude-sonnet-4-5-20250929, claude-opus-4-20250514
LLM_MODEL=claude-sonnet-4-5-20250929

# =============================================================================
# Authentication mode
# =============================================================================
# Options: local, openrouter, anthropic, manual
PENTESTGPT_AUTH_MODE=local

# Anthropic API key, used when PENTESTGPT_AUTH_MODE=anthropic
ANTHROPIC_API_KEY=

# OpenRouter API key, used when PENTESTGPT_AUTH_MODE=openrouter
OPENROUTER_API_KEY=

# =============================================================================
# SSH access
# =============================================================================
# Password for the `pentester` account
PENTESTGPT_SSH_PASSWORD=pentestgpt

# Host port for SSH (docker-compose.yml: host-side mapping only, container
# always listens on 22. docker-compose.host.yml: the actual port sshd binds to
# on the VM, since there's no port mapping under host networking.)
PENTESTGPT_SSH_PORT=2222

# =============================================================================
# Web config UI
# =============================================================================
# Host port for the web config UI (same host-mapping-vs-actual-bind-port
# distinction between the two compose files as PENTESTGPT_SSH_PORT above)
PENTESTGPT_WEB_PORT=8080

# Bind address for the web config UI inside the container. Only meaningful with
# docker-compose.host.yml -- with the bridge docker-compose.yml, Compose's
# "127.0.0.1:..." port mapping already restricts access to localhost regardless
# of this value. Set to 127.0.0.1 to restrict host-network access too.
PENTESTGPT_WEB_HOST=0.0.0.0
